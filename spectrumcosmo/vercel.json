{
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install --legacy-peer-deps",
  "crons": [
    {
      "path": "/api/cron/abandon-carts",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/refresh-rules",
      "schedule": "*/5 * * * *"
    }
  ]
}
